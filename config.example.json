{
  "active_library": 1,
  "db_path": "",
  "autosave_interval": 60,
  "targets": {
    "plex": {
      "base_url": "http://your-plex-server:32400",
      "token": "your-plex-token",
      "music_section": "Music",
      "path_rules": []
    },
    "m3u": {
      "path_style": "absolute",
      "base_path": "",
      "path_rules": []
    }
  },
  "cron": {
    "library": "My Collection",
    "mode": "plex",
    "profile": "",
    "m3u_output_dir": "~/Playlists",
    "verbosity": "-q"
  },
  "webhook": {
    "host": "0.0.0.0",
    "port": 5588,
    "library": "My Collection",
    "allowed_commands": ["plex", "scan", "scan+plex", "scan+m3u", "m3u"]
  }
}
